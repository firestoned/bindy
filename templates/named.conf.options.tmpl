options {
    directory "/var/cache/bind";
    pid-file "/var/cache/bind/named.pid";
    session-keyfile "/var/cache/bind/session.key";
    dump-file "/var/cache/bind/cache_dump.db";
    statistics-file "/var/cache/bind/named_stats.txt";
    memstatistics-file "/var/cache/bind/named_mem_stats.txt";
    // named listens on the unprivileged DNS port 5353 (no NET_BIND_SERVICE
    // capability needed). The DNS Service exposes 53 to clients and forwards to
    // 5353; secondary-zone `primaries` and `also-notify` are port-qualified
    // (`<ip>:5353`) so cross-pod transfers reach this port (bindcar 0.7.2+).
    // Defaults to `any` unless listenOn / listenOnV6 are set in the CRD.
    {{LISTEN_ON}}
    {{LISTEN_ON_V6}}
    allow-new-zones yes;
    {{RECURSION}}
    {{FORWARDERS}}
    {{ALLOW_QUERY}}
    {{ALLOW_TRANSFER}}
    {{DNSSEC_VALIDATE}}
};

{{DNSSEC_POLICIES}}
