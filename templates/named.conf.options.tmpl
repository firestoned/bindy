options {
    directory "/var/cache/bind";
    pid-file "/var/cache/bind/named.pid";
    session-keyfile "/var/cache/bind/session.key";
    dump-file "/var/cache/bind/cache_dump.db";
    statistics-file "/var/cache/bind/named_stats.txt";
    memstatistics-file "/var/cache/bind/named_mem_stats.txt";
    // bindcar 0.7.0 migration: named listens on the standard DNS port 53
    // (bound as non-root via the NET_BIND_SERVICE capability). Secondary-zone
    // `primaries` entries are plain IPs, so zone transfers use this port.
    // Defaults to `any` unless listenOn / listenOnV6 are set in the CRD.
    {{LISTEN_ON}}
    {{LISTEN_ON_V6}}
    allow-new-zones yes;
    {{RECURSION}}
    {{FORWARDERS}}
    {{ALLOW_QUERY}}
    {{ALLOW_TRANSFER}}
    {{DNSSEC_VALIDATE}}
};

{{DNSSEC_POLICIES}}
